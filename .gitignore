*.key

# ── Trained ML Models (large files) ──────────────────────
backend/data/models/*.pkl
backend/data/models/*.keras
backend/data/models/*.h5
backend/data/models/*.joblib

# ── Downloaded Datasets (regenerated by script) ───────────
data/symptom_disease/*.csv
data/medicine/*.csv
data/medical_qa/*.csv
data/medical_qa/*.json
# Keep built-in JSONs
!data/symptom_disease/disease_symptoms.json
!data/symptom_disease/all_symptoms.json
!data/symptom_disease/symptom_severity.json
!data/medicine/home_remedies.json
!data/medicine/otc_medicines.json
!data/multilingual/medical_vocabulary.json

